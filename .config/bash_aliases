# general aliases
alias ebashrc='vim ~/.bashrc'
alias sbashrc='source ~/.bashrc'
alias godev='cd ~/dev'

# git aliases
alias gnb='git checkout -b '
alias gpb='git checkout -'
alias ghard='git reset --hard && git clean -df && git status'
alias gc='git add --all && git commit -m '
alias gcane='git add --all && git commit --amend --no-edit'
alias gfap='git fetch --all --prune'
alias gcloc='git ls-files "*.js" "*.jsx" "*.ts" "*.tsx" | xargs wc -l'
alias grc='git add --all && git rebase --continue'
alias gdef="git symbolic-ref --short refs/remotes/origin/HEAD | sed 's@^origin/@@'"
alias gmr='git checkout $(gdef) && git pull origin $(gdef) && gfap && printf "\nCurrent branches\n" && git branch'
alias gpr='git pull --rebase'

# awt <branch-name> <codex|claude|copilot|gemini> [yolo]
# Creates a sibling git worktree, cds into it, and launches the selected agent.
awt() {
  local branch_name="$1"
  local agent_name="$2"
  local launch_mode="$3"
  local git_root
  local repo_name
  local parent_dir
  local worktree_dir

  if [[ -z "$branch_name" || -z "$agent_name" ]]; then
    echo "Usage: awt <branch-name> <codex|claude|copilot|gemini> [yolo]"
    return 1
  fi

  if ! git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "awt must be run from inside a git repository"
    return 1
  fi

  case "$agent_name" in
    codex|claude|copilot|gemini)
      ;;
    *)
      echo "Unsupported agent: $agent_name"
      echo "Supported agents: codex, claude, copilot, gemini"
      return 1
      ;;
  esac

  if ! command -v "$agent_name" >/dev/null 2>&1; then
    echo "Agent command not found: $agent_name"
    return 1
  fi

  repo_name="$(basename "$git_root")"
  parent_dir="$(dirname "$git_root")"
  worktree_dir="$parent_dir/$repo_name-$branch_name"

  if [[ -e "$worktree_dir" ]]; then
    echo "Worktree path already exists: $worktree_dir"
    return 1
  fi

  if git show-ref --verify --quiet "refs/heads/$branch_name"; then
    git -C "$git_root" worktree add "$worktree_dir" "$branch_name" || return 1
  else
    git -C "$git_root" worktree add -b "$branch_name" "$worktree_dir" || return 1
  fi

  cd "$worktree_dir" || return 1

  if [[ "$launch_mode" == "yolo" ]]; then
    yolo "$agent_name"
  else
    "$agent_name"
  fi
}

# yolo <codex|claude|copilot|gemini>
# Launches the selected agent in the current directory with its most permissive mode.
yolo() {
  local agent_name="$1"
  local -a agent_cmd

  if [[ -z "$agent_name" ]]; then
    echo "Usage: yolo <codex|claude|copilot|gemini>"
    return 1
  fi

  case "$agent_name" in
    codex)
      agent_cmd=(codex --dangerously-bypass-approvals-and-sandbox)
      ;;
    claude)
      agent_cmd=(claude --dangerously-skip-permissions)
      ;;
    copilot)
      agent_cmd=(copilot --allow-all-tools --allow-all-paths)
      ;;
    gemini)
      agent_cmd=(gemini --yolo)
      ;;
    *)
      echo "Unsupported agent: $agent_name"
      echo "Supported agents: codex, claude, copilot, gemini"
      return 1
      ;;
  esac

  if ! command -v "${agent_cmd[0]}" >/dev/null 2>&1; then
    echo "Agent command not found: ${agent_cmd[0]}"
    return 1
  fi

  "${agent_cmd[@]}"
}
