# general aliases
alias ebashrc='vim ~/.bashrc'
alias sbashrc='source ~/.bashrc'
alias godev='cd ~/dev'

# git aliases
alias gnb='git checkout -b '
alias gpb='git checkout -'
alias ghard='git reset --hard && git clean -df && git status'
alias gc='git add --all && git commit -m '
alias gcane='git add --all && git commit --amend --no-edit'
alias gfap='git fetch --all --prune'
alias gcloc='git ls-files "*.js" "*.jsx" "*.ts" "*.tsx" | xargs wc -l'
alias grc='git add --all && git rebase --continue'
alias gdef="git symbolic-ref --short refs/remotes/origin/HEAD | sed 's@^origin/@@'"
alias gmr='git checkout $(gdef) && git pull origin $(gdef) && gfap && printf "\nCurrent branches\n" && git branch'
alias gpr='git pull --rebase'

# cwt <branch-name> [command...]
# Creates a sibling git worktree, cds into it, and runs the optionally provided command.
cwt() {
  local branch_name="$1"

  local git_root
  local repo_name
  local parent_dir
  local worktree_dir
  local command_string

  if [[ -z "$branch_name" ]]; then
    echo "Usage: cwt <branch-name> [command...]"
    return 1
  fi

  shift

  if ! git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "cwt must be run from inside a git repository"
    return 1
  fi

  repo_name="$(basename "$git_root")"
  parent_dir="$(dirname "$git_root")"
  worktree_dir="$parent_dir/$repo_name-$branch_name"

  if [[ -e "$worktree_dir" ]]; then
    echo "Worktree path already exists: $worktree_dir"
    return 1
  fi

  if git show-ref --verify --quiet "refs/heads/$branch_name"; then
    printf '+ git -C %q worktree add %q %q\n' "$git_root" "$worktree_dir" "$branch_name"
    git -C "$git_root" worktree add "$worktree_dir" "$branch_name" || return 1
  else
    printf '+ git -C %q worktree add -b %q %q\n' "$git_root" "$branch_name" "$worktree_dir"
    git -C "$git_root" worktree add -b "$branch_name" "$worktree_dir" || return 1
  fi

  printf '+ cd %q\n' "$worktree_dir"
  cd "$worktree_dir" || return 1

  if [[ "$#" -eq 0 ]]; then
    return 0
  fi

  printf -v command_string '%q ' "$@"
  printf '+ %s\n' "${command_string% }"
  eval "${command_string% }"
}

# ewt [--delete]
# Exits a linked git worktree back to the original repo checkout.
# Pass --delete to remove the current worktree after leaving it.
ewt() {
  local delete_worktree=0
  local current_root
  local common_dir
  local original_repo

  case "$1" in
    "")
      ;;
    --delete)
      delete_worktree=1
      ;;
    *)
      echo "Usage: ewt [--delete]"
      return 1
      ;;
  esac

  if ! current_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "ewt must be run from inside a git repository"
    return 1
  fi

  if ! common_dir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"; then
    echo "Unable to determine the repo common directory"
    return 1
  fi

  original_repo="$(dirname "$common_dir")"

  if [[ "$current_root" == "$original_repo" ]]; then
    if (( delete_worktree )); then
      echo "Refusing to delete the original repo checkout"
      return 1
    fi

    printf '+ cd %q\n' "$original_repo"
    cd "$original_repo" || return 1
    return 0
  fi

  printf '+ cd %q\n' "$original_repo"
  cd "$original_repo" || return 1

  if (( delete_worktree )); then
    printf '+ git -C %q worktree remove %q\n' "$original_repo" "$current_root"
    git -C "$original_repo" worktree remove "$current_root" || return 1
  fi
}

# yolo <codex|claude|copilot|gemini> [args...]
# Launches the selected agent in the current directory with its most permissive mode through sbx.
yolo() {
  local agent_name="$1"

  if [[ -z "$agent_name" ]]; then
    echo "Usage: yolo <codex|claude|copilot|gemini> [args...]"
    return 1
  fi

  shift

  case "$agent_name" in
    codex|claude|copilot|gemini)
      ;;
    *)
      echo "Unsupported agent: $agent_name"
      echo "Supported agents: codex, claude, copilot, gemini"
      return 1
      ;;
  esac

  if ! command -v sbx >/dev/null 2>&1; then
    echo "Sandbox command not found: sbx"
    return 1
  fi

  sbx run "$agent_name" -- "$@"
}
